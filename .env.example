# Azure OpenAI Configuration
# Azure App Service environment variable names (used in production):
AZURE_AI_API_KEY=your-api-key-here
AZURE_AI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# Legacy / local development environment variable names (also supported):
# AZURE_OPENAI_API_KEY=your-api-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name

# Azure AI Search (Optional)
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_API_KEY=your-search-api-key
AZURE_SEARCH_INDEX_NAME=your-index-name

# Azure Cognitive Services (Optional)
AZURE_COGNITIVE_SERVICES_ENDPOINT=https://your-cognitive-service.cognitiveservices.azure.com/
AZURE_COGNITIVE_SERVICES_API_KEY=your-cognitive-services-key

# Application Settings
FLASK_ENV=development
LOG_LEVEL=INFO

# Stripe Payment Configuration (CMS subscription billing)
# Use test-mode keys (pk_test_ / sk_test_) for development, live keys for production.
# See docs/STRIPE_SETUP.md for full instructions.
Payment__Stripe__PublishableKey=pk_test_your-publishable-key
Payment__Stripe__SecretKey=sk_test_your-secret-key
Payment__Stripe__WebhookSecret=whsec_your-webhook-secret

# Stripe Price IDs – create these in your Stripe Dashboard > Products, then paste the IDs here.
Payment__Stripe__PriceIds__Starter_Monthly=price_your-starter-monthly-id
Payment__Stripe__PriceIds__Starter_Yearly=price_your-starter-yearly-id
Payment__Stripe__PriceIds__Pro_Monthly=price_your-pro-monthly-id
Payment__Stripe__PriceIds__Pro_Yearly=price_your-pro-yearly-id
Payment__Stripe__PriceIds__Business_Monthly=price_your-business-monthly-id
Payment__Stripe__PriceIds__Business_Yearly=price_your-business-yearly-id
