# Database Configuration
# For development: use SQLite (default)
# For production: use PostgreSQL as shown below
DATABASE_URL=postgresql://user:password@localhost:5432/orkinosai_cms
# Development alternative: DATABASE_URL=sqlite:///./orkinosai.db

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Azure Configuration (Placeholder)
AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string
AZURE_STORAGE_CONTAINER_NAME=orkinosai-documents
AZURE_AI_ENDPOINT=your-azure-ai-endpoint
AZURE_AI_KEY=your-azure-ai-key

# Application Settings
APP_NAME=Orkinosai CMS
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True
