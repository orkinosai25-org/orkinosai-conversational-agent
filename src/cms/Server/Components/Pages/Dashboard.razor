@page "/dashboard"
@using PapaganCMS.Shared.DTOs.Bots
@using PapaganCMS.Shared.DTOs.Auth
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Dashboard - Papagan</PageTitle>

<div class="dashboard-container">
    <div class="dashboard-header">
        <h1>🦜 My Seats</h1>
        <button class="btn btn-primary" @onclick="ShowCreateBotModal">
            <span>➕ Create New Seat</span>
        </button>
    </div>

    @if (isLoading)
    {
        <div class="loading">
            <div class="spinner-border" role="status">
                <span class="sr-only">Loading...</span>
            </div>
            <p>Loading your bots...</p>
        </div>
    }
    else if (bots == null || !bots.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">🤖</div>
            <h2>No seats yet</h2>
            <p>Create your first chatbot seat to get started.</p>
            <button class="btn btn-primary btn-lg" @onclick="ShowCreateBotModal">
                Create Your First Seat
            </button>
        </div>
    }
    else
    {
        <div class="bots-grid">
            @foreach (var bot in bots)
            {
                <div class="bot-card">
                    <div class="bot-header">
                        <div class="bot-avatar">
                            @if (!string.IsNullOrEmpty(bot.AvatarUrl))
                            {
                                <img src="@bot.AvatarUrl" alt="@bot.Name" />
                            }
                            else
                            {
                                <span class="avatar-placeholder">🤖</span>
                            }
                        </div>
                        <div class="bot-info">
                            <h3>@bot.Name</h3>
                            <p class="bot-description">@bot.Description</p>
                        </div>
                    </div>

                    <div class="bot-stats">
                        <div class="stat">
                            <span class="stat-icon">📄</span>
                            <div>
                                <div class="stat-value">@bot.TrainedDocumentsCount</div>
                                <div class="stat-label">Documents</div>
                            </div>
                        </div>
                        <div class="stat">
                            <span class="stat-icon">🔗</span>
                            <div>
                                <div class="stat-value">@bot.TrainedUrlsCount</div>
                                <div class="stat-label">URLs</div>
                            </div>
                        </div>
                        <div class="stat">
                            <span class="stat-icon">@(bot.IsActive ? "✅" : "⏸️")</span>
                            <div>
                                <div class="stat-value">@(bot.IsActive ? "Active" : "Inactive")</div>
                                <div class="stat-label">Status</div>
                            </div>
                        </div>
                    </div>

                    @if (bot.LastTrainedAt.HasValue)
                    {
                        <div class="bot-footer">
                            <small>Last trained: @bot.LastTrainedAt.Value.ToString("MMM dd, yyyy")</small>
                        </div>
                    }

                    <div class="bot-actions">
                        <button class="btn btn-sm btn-secondary" @onclick="() => ManageBot(bot.Id)">
                            ⚙️ Manage
                        </button>
                        <button class="btn btn-sm btn-primary" @onclick="() => ChatWithBot(bot.Id)">
                            💬 Chat
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    @if (showCreateModal)
    {
        <div class="modal-overlay" @onclick="HideCreateBotModal">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h2>Create New Seat</h2>
                    <button class="close-btn" @onclick="HideCreateBotModal">×</button>
                </div>

                <div class="modal-body">
                    <EditForm Model="@createBotDto" OnValidSubmit="@CreateBot">
                        <div class="form-group">
                            <label>Site URL / Domain *</label>
                            <InputText class="form-control" @bind-Value="createBotDto.SiteUrl" placeholder="https://example.com" />
                        </div>

                        <div class="form-group">
                            <label>Bot Name *</label>
                            <InputText class="form-control" @bind-Value="createBotDto.Name" placeholder="Customer Support Bot" />
                        </div>

                        <div class="form-group">
                            <label>Description</label>
                            <InputTextArea class="form-control" @bind-Value="createBotDto.Description" placeholder="What will this bot do?" rows="3" />
                        </div>

                        <div class="form-group">
                            <label>System Prompt (Optional)</label>
                            <InputTextArea class="form-control" @bind-Value="createBotDto.SystemPrompt" placeholder="You are a helpful assistant that..." rows="3" />
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Temperature</label>
                                <InputNumber class="form-control" @bind-Value="createBotDto.Temperature" min="0" max="1" step="0.1" />
                                <small>0 = Focused, 1 = Creative</small>
                            </div>

                            <div class="form-group">
                                <label>Max Tokens</label>
                                <InputNumber class="form-control" @bind-Value="createBotDto.MaxTokens" min="100" max="4000" />
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger">
                                @errorMessage
                            </div>
                        }

                        <div class="modal-actions">
                            <button type="button" class="btn btn-secondary" @onclick="HideCreateBotModal">Cancel</button>
                            <button type="submit" class="btn btn-primary" disabled="@isCreating">
                                @if (isCreating)
                                {
                                    <span class="spinner-border spinner-border-sm"></span>
                                    <span> Creating...</span>
                                }
                                else
                                {
                                    <span>Create Seat</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .dashboard-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
    }

    .dashboard-header h1 {
        font-size: 2.5em;
        margin: 0;
        color: #333;
    }

    .loading {
        text-align: center;
        padding: 60px 20px;
    }

    .empty-state {
        text-align: center;
        padding: 80px 20px;
    }

    .empty-icon {
        font-size: 6em;
        margin-bottom: 20px;
    }

    .empty-state h2 {
        font-size: 2em;
        margin-bottom: 15px;
        color: #666;
    }

    .empty-state p {
        font-size: 1.2em;
        color: #999;
        margin-bottom: 30px;
    }

    .bots-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 25px;
    }

    .bot-card {
        background: white;
        border: 1px solid #e0e0e0;
        border-radius: 12px;
        padding: 25px;
        transition: all 0.3s;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .bot-card:hover {
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
        transform: translateY(-2px);
    }

    .bot-header {
        display: flex;
        gap: 15px;
        margin-bottom: 20px;
    }

    .bot-avatar {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        overflow: hidden;
        background: #f5f5f5;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .bot-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .avatar-placeholder {
        font-size: 2em;
    }

    .bot-info h3 {
        margin: 0 0 8px 0;
        font-size: 1.4em;
        color: #333;
    }

    .bot-description {
        margin: 0;
        color: #666;
        font-size: 0.95em;
    }

    .bot-stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
        margin: 20px 0;
        padding: 20px 0;
        border-top: 1px solid #e0e0e0;
        border-bottom: 1px solid #e0e0e0;
    }

    .stat {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .stat-icon {
        font-size: 1.5em;
    }

    .stat-value {
        font-size: 1.3em;
        font-weight: 600;
        color: #333;
    }

    .stat-label {
        font-size: 0.85em;
        color: #666;
    }

    .bot-footer {
        margin: 15px 0;
    }

    .bot-footer small {
        color: #999;
    }

    .bot-actions {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }

    .btn {
        padding: 10px 20px;
        border-radius: 6px;
        font-weight: 500;
        cursor: pointer;
        border: none;
        transition: all 0.3s;
    }

    .btn-sm {
        padding: 8px 16px;
        font-size: 0.9em;
    }

    .btn-lg {
        padding: 14px 30px;
        font-size: 1.2em;
    }

    .btn-primary {
        background: #4CAF50;
        color: white;
    }

    .btn-primary:hover:not(:disabled) {
        background: #2E7D32;
    }

    .btn-secondary {
        background: #e0e0e0;
        color: #333;
    }

    .btn-secondary:hover {
        background: #bdbdbd;
    }

    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .modal-content {
        background: white;
        border-radius: 12px;
        max-width: 600px;
        width: 90%;
        max-height: 90vh;
        overflow-y: auto;
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 25px;
        border-bottom: 1px solid #e0e0e0;
    }

    .modal-header h2 {
        margin: 0;
        font-size: 1.8em;
    }

    .close-btn {
        background: none;
        border: none;
        font-size: 2em;
        cursor: pointer;
        color: #666;
        line-height: 1;
    }

    .modal-body {
        padding: 25px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        font-weight: 500;
        margin-bottom: 8px;
        display: block;
        color: #333;
    }

    .form-control {
        width: 100%;
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-size: 1em;
    }

    .form-control:focus {
        outline: none;
        border-color: #4CAF50;
        box-shadow: 0 0 0 3px rgba(76, 175, 80, 0.1);
    }

    .form-group small {
        display: block;
        margin-top: 5px;
        color: #666;
        font-size: 0.875em;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    .modal-actions {
        display: flex;
        gap: 15px;
        justify-content: flex-end;
        margin-top: 25px;
    }

    .alert {
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 20px;
    }

    .alert-danger {
        background: #ffebee;
        color: #c62828;
        border: 1px solid #ef9a9a;
    }
</style>

@code {
    private List<BotDto>? bots;
    private bool isLoading = true;
    private bool showCreateModal = false;
    private bool isCreating = false;
    private string? errorMessage;
    private CreateBotDto createBotDto = new() { Temperature = 0.7, MaxTokens = 1000 };

    protected override async Task OnInitializedAsync()
    {
        await LoadBots();
    }

    private async Task LoadBots()
    {
        try
        {
            isLoading = true;
            var response = await Http.GetAsync("/api/bot");
            if (response.IsSuccessStatusCode)
            {
                bots = await response.Content.ReadFromJsonAsync<List<BotDto>>();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading bots: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowCreateBotModal()
    {
        createBotDto = new() { Temperature = 0.7, MaxTokens = 1000 };
        errorMessage = null;
        showCreateModal = true;
    }

    private void HideCreateBotModal()
    {
        showCreateModal = false;
        errorMessage = null;
    }

    private async Task CreateBot()
    {
        try
        {
            isCreating = true;
            errorMessage = null;

            var response = await Http.PostAsJsonAsync("/api/seats", createBotDto);
            if (response.IsSuccessStatusCode)
            {
                var newBot = await response.Content.ReadFromJsonAsync<BotDto>();
                if (newBot != null)
                {
                    bots ??= new List<BotDto>();
                    bots.Insert(0, newBot);
                    if (!string.IsNullOrWhiteSpace(newBot.SeatSlug))
                    {
                        HideCreateBotModal();
                        Navigation.NavigateTo($"/c/{newBot.SeatSlug}");
                        return;
                    }
                }

                HideCreateBotModal();
            }
            else
            {
                errorMessage = "Failed to create seat. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "An error occurred. Please try again.";
        }
        finally
        {
            isCreating = false;
        }
    }

    private void ManageBot(string botId)
    {
        Navigation.NavigateTo($"/bot/{botId}");
    }

    private void ChatWithBot(string botId)
    {
        Navigation.NavigateTo($"/chat/{botId}");
    }
}
