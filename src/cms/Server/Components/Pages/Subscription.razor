@page "/subscription"
@inject HttpClient Http
@inject NavigationManager Navigation
@using SiteChatCMS.Shared.DTOs.Subscriptions
@using Microsoft.AspNetCore.Components.WebAssembly.Http

<PageTitle>My Subscription - Orkinosai CMS</PageTitle>

<div class="subscription-page">
    <h1>My Subscription</h1>

    @if (loading)
    {
        <div class="loading">
            <p>Loading subscription details...</p>
        </div>
    }
    else if (subscription != null)
    {
        <div class="subscription-details">
            <div class="plan-info">
                <h2>@subscription.Tier Plan</h2>
                <p class="status @subscription.Status.ToLower()">Status: @subscription.Status</p>
                
                @if (subscription.Tier != "Free")
                {
                    <div class="price-info">
                        <p class="price">
                            $@subscription.PriceAmount.ToString("0.00") / @subscription.BillingInterval.ToLower()
                        </p>
                    </div>
                    
                    <div class="billing-info">
                        <p><strong>Current Period:</strong></p>
                        <p>@subscription.CurrentPeriodStart.ToShortDateString() - @subscription.CurrentPeriodEnd.ToShortDateString()</p>
                        
                        @if (subscription.CancelAtPeriodEnd)
                        {
                            <p class="warning">Your subscription will end on @subscription.CurrentPeriodEnd.ToShortDateString()</p>
                        }
                    </div>
                }
            </div>

            <div class="limits-info">
                <h3>Plan Limits</h3>
                <div class="limits-grid">
                    <div class="limit-item">
                        <strong>Websites</strong>
                        <span>@subscription.Limits.MaxWebsites</span>
                    </div>
                    <div class="limit-item">
                        <strong>Storage</strong>
                        <span>@FormatBytes(subscription.Limits.MaxStorageBytes)</span>
                    </div>
                    <div class="limit-item">
                        <strong>Bandwidth</strong>
                        <span>@FormatBytes(subscription.Limits.MaxBandwidthBytes)</span>
                    </div>
                    <div class="limit-item">
                        <strong>Custom Domains</strong>
                        <span>@subscription.Limits.MaxCustomDomains</span>
                    </div>
                </div>
            </div>

            <div class="actions">
                @if (subscription.Tier == "Free")
                {
                    <button class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/pricing"))">
                        Upgrade Plan
                    </button>
                }
                else
                {
                    <button class="btn btn-secondary" @onclick="OpenBillingPortal">
                        Manage Billing
                    </button>
                    
                    <button class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/pricing"))">
                        Change Plan
                    </button>
                    
                    @if (!subscription.CancelAtPeriodEnd)
                    {
                        <button class="btn btn-danger" @onclick="CancelSubscription">
                            Cancel Subscription
                        </button>
                    }
                }
            </div>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="error">
            <p>@errorMessage</p>
            <button class="btn btn-primary" @onclick="LoadSubscriptionAsync">
                Retry
            </button>
        </div>
    }
</div>

@code {
    private SubscriptionDto? subscription;
    private bool loading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadSubscriptionAsync();
    }

    private async Task LoadSubscriptionAsync()
    {
        try
        {
            loading = true;
            errorMessage = null;
            
            // TODO: Get user email from authentication
            var userEmail = "demo@example.com";
            
            var request = new HttpRequestMessage(HttpMethod.Get, $"/api/subscription/current?userEmail={userEmail}");
            request.SetBrowserRequestMode(BrowserRequestMode.Cors);
            
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                subscription = await response.Content.ReadFromJsonAsync<SubscriptionDto>();
            }
            else
            {
                errorMessage = "Failed to load subscription details. Please try again later.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading subscription: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task OpenBillingPortal()
    {
        try
        {
            // TODO: Get user email from authentication
            var userEmail = "demo@example.com";
            
            var portalDto = new BillingPortalSessionDto
            {
                ReturnUrl = $"{Navigation.BaseUri}subscription"
            };
            
            var request = new HttpRequestMessage(HttpMethod.Post, $"/api/subscription/billing-portal?userEmail={userEmail}")
            {
                Content = JsonContent.Create(portalDto)
            };
            request.SetBrowserRequestMode(BrowserRequestMode.Cors);
            
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var portalResponse = await response.Content.ReadFromJsonAsync<BillingPortalResponseDto>();
                if (portalResponse?.PortalUrl != null)
                {
                    Navigation.NavigateTo(portalResponse.PortalUrl, forceLoad: true);
                }
            }
            else
            {
                errorMessage = "Failed to open billing portal. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error opening billing portal: {ex.Message}";
        }
    }

    private async Task CancelSubscription()
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to cancel your subscription? It will remain active until the end of the current billing period."))
        {
            return;
        }

        try
        {
            // TODO: Get user email from authentication
            var userEmail = "demo@example.com";
            
            var request = new HttpRequestMessage(HttpMethod.Delete, $"/api/subscription/cancel?userEmail={userEmail}&cancelAtPeriodEnd=true");
            request.SetBrowserRequestMode(BrowserRequestMode.Cors);
            
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                await LoadSubscriptionAsync();
            }
            else
            {
                errorMessage = "Failed to cancel subscription. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error canceling subscription: {ex.Message}";
        }
    }

    private string FormatBytes(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.#}{sizes[order]}";
    }

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = default!;
}

<style>
    .subscription-page {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .subscription-page h1 {
        font-size: 2.5rem;
        margin-bottom: 2rem;
        color: #333;
    }

    .subscription-details {
        background: white;
        border-radius: 12px;
        padding: 2rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .plan-info {
        border-bottom: 1px solid #e0e0e0;
        padding-bottom: 2rem;
        margin-bottom: 2rem;
    }

    .plan-info h2 {
        font-size: 2rem;
        margin-bottom: 1rem;
        color: #333;
    }

    .status {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 1rem;
    }

    .status.active {
        color: #4CAF50;
    }

    .status.canceled {
        color: #f44336;
    }

    .price-info {
        margin: 1.5rem 0;
    }

    .price {
        font-size: 1.8rem;
        font-weight: 700;
        color: #333;
    }

    .billing-info {
        margin-top: 1.5rem;
        color: #666;
    }

    .billing-info p {
        margin: 0.5rem 0;
    }

    .warning {
        color: #ff9800;
        font-weight: 600;
        margin-top: 1rem;
    }

    .limits-info {
        margin-bottom: 2rem;
    }

    .limits-info h3 {
        font-size: 1.5rem;
        margin-bottom: 1rem;
        color: #333;
    }

    .limits-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
    }

    .limit-item {
        background: #f5f5f5;
        padding: 1.5rem;
        border-radius: 8px;
        text-align: center;
    }

    .limit-item strong {
        display: block;
        margin-bottom: 0.5rem;
        color: #666;
        font-size: 0.9rem;
    }

    .limit-item span {
        font-size: 1.5rem;
        font-weight: 700;
        color: #333;
    }

    .actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .btn {
        padding: 12px 24px;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-primary {
        background: #2196F3;
        color: white;
    }

    .btn-primary:hover {
        background: #1976D2;
    }

    .btn-secondary {
        background: #757575;
        color: white;
    }

    .btn-secondary:hover {
        background: #616161;
    }

    .btn-danger {
        background: #f44336;
        color: white;
    }

    .btn-danger:hover {
        background: #d32f2f;
    }

    .loading, .error {
        text-align: center;
        padding: 3rem 1rem;
    }

    .error {
        color: #f44336;
    }
</style>
