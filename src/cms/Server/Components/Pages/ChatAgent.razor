@page "/chat"
@page "/chat/{BotId}"
@page "/c/{SeatSlug}"
@using PapaganCMS.Shared.DTOs.Bots
@inject IJSRuntime JSRuntime
@inject IHttpClientFactory HttpClientFactory
@inject ILogger<ChatAgent> Logger
@inject HttpClient Http

<PageTitle>@(string.IsNullOrWhiteSpace(seatContextLabel) ? "Orkinosai Chat Agent" : $"Chat with {seatContextLabel} | Orkinosai")</PageTitle>

<div class="chat-container">
    <div class="chat-header">
        <h3><i class="fas fa-robot"></i> Orkinosai Conversational Agent</h3>
        <button class="btn-clear" @onclick="ClearConversation">
            <i class="fas fa-trash"></i> Clear
        </button>
    </div>
    @if (!string.IsNullOrWhiteSpace(seatContextLabel))
    {
        <div class="seat-context-banner">
            You are chatting with the assistant for <strong>@seatContextLabel</strong>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(trainingManageUrl) && !isPublicMode)
    {
        <div class="seat-context-banner seat-training-banner">
            <strong>Train your bot from your website or documents before going live.</strong>
            <a href="@trainingManageUrl">Open training</a>
            <span> | </span>
            <a href="@trainingUrlsApiUrl">@trainingUrlsApiUrl</a>
            <span> | </span>
            <a href="@trainingDocumentsApiUrl">@trainingDocumentsApiUrl</a>
        </div>
    }

    <div class="chat-messages" id="chatMessages">
        @foreach (var message in messages)
        {
            <div class="message @message.Role">
                <div class="message-content">
                    <strong>@(message.Role == "user" ? "You" : "Agent"):</strong>
                    <p>@message.Content</p>
                    <small>@message.Timestamp.ToString("HH:mm:ss")</small>
                </div>
            </div>
        }
        @if (isLoading)
        {
            <div class="message assistant">
                <div class="message-content">
                    <div class="typing-indicator">
                        <span></span>
                        <span></span>
                        <span></span>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="chat-input-container">
        <textarea @bind="userMessage" 
                  @bind:event="oninput"
                  @onkeydown="HandleKeyPress"
                  placeholder="Type your message here..."
                  rows="3"
                  class="chat-input"
                  disabled="@isLoading"></textarea>
        <button class="btn-send" @onclick="SendMessage" disabled="@(isLoading || string.IsNullOrWhiteSpace(userMessage))">
            <i class="fas fa-paper-plane"></i> Send
        </button>
    </div>

    <div class="chat-settings">
        <div class="setting-group">
            <label>Temperature: @temperature.ToString("0.0")</label>
            <input type="range" min="0" max="1" step="0.1" @bind="temperature" @bind:event="oninput" />
        </div>
        <div class="setting-group">
            <label>Max Tokens: @maxTokens</label>
            <input type="range" min="100" max="2000" step="100" @bind="maxTokens" @bind:event="oninput" />
        </div>
    </div>
</div>

@code {
    [Parameter] public string? BotId { get; set; }
    [Parameter] public string? SeatSlug { get; set; }

    private List<ChatMessage> messages = new();
    private string userMessage = "";
    private bool isLoading = false;
    private string conversationId = Guid.NewGuid().ToString();
    private double temperature = 0.7;
    private int maxTokens = 1000;
    private HttpClient? httpClient;
    private string? seatId;
    private string? allowedDomain;
    private string seatContextLabel = string.Empty;
    private bool isPublicMode = false;
    private string trainingManageUrl = string.Empty;
    private string trainingUrlsApiUrl = string.Empty;
    private string trainingDocumentsApiUrl = string.Empty;

    private class ChatMessage
    {
        public string Role { get; set; } = "";
        public string Content { get; set; } = "";
        public DateTime Timestamp { get; set; } = DateTime.Now;
    }

    protected override async Task OnInitializedAsync()
    {
        // Get HttpClient from factory
        httpClient = HttpClientFactory.CreateClient("ChatBackend");
        await LoadSeatContext();
        
        // Add welcome message
        messages.Add(new ChatMessage 
        { 
            Role = "assistant", 
            Content = "Hello! I'm Orkinosai, your AI assistant. How can I help you today?",
            Timestamp = DateTime.Now
        });
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userMessage) || isLoading)
            return;

        var message = userMessage.Trim();
        userMessage = "";
        
        // Add user message
        messages.Add(new ChatMessage 
        { 
            Role = "user", 
            Content = message,
            Timestamp = DateTime.Now
        });

        isLoading = true;
        StateHasChanged();

        try
        {
            if (httpClient == null)
            {
                Logger.LogError("HttpClient is not initialized");
                throw new InvalidOperationException("HttpClient not initialized");
            }

            Logger.LogInformation("Sending chat message to backend");
            
            // Call the Python backend chat API
            var response = await httpClient.PostAsJsonAsync("/chat", new
            {
                conversation_id = conversationId,
                message = message,
                seat_id = seatId,
                temperature = temperature,
                max_tokens = maxTokens
            });

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ChatResponse>();
                
                if (result != null && !string.IsNullOrEmpty(result.assistant_message))
                {
                    messages.Add(new ChatMessage 
                    { 
                        Role = "assistant", 
                        Content = SanitizeLinksForSeat(result.assistant_message),
                        Timestamp = DateTime.Now
                    });
                    Logger.LogInformation("Received successful response from backend");
                }
            }
            else
            {
                Logger.LogWarning("Backend returned error status: {StatusCode}", response.StatusCode);
                messages.Add(new ChatMessage 
                { 
                    Role = "assistant", 
                    Content = $"Sorry, I encountered an error (Status: {response.StatusCode}). Please make sure the Python backend is running.",
                    Timestamp = DateTime.Now
                });
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error communicating with chat backend");
            messages.Add(new ChatMessage 
            { 
                Role = "assistant", 
                Content = $"Error connecting to backend: {ex.Message}. Please ensure the Python server is running.",
                Timestamp = DateTime.Now
            });
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }

    private async Task ClearConversation()
    {
        messages.Clear();
        conversationId = BuildConversationId(seatId);
        
        messages.Add(new ChatMessage 
        { 
            Role = "assistant", 
            Content = "Conversation cleared. How can I help you?",
            Timestamp = DateTime.Now
        });
        
        StateHasChanged();
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("scrollToBottom", "chatMessages");
        }
        catch (Exception ex)
        {
            // Log JS interop errors for debugging
            Logger.LogDebug(ex, "JS interop error when scrolling to bottom");
        }
    }

    private class ChatResponse
    {
        public string? conversation_id { get; set; }
        public string? user_message { get; set; }
        public string? assistant_message { get; set; }
        public object? usage { get; set; }
        public string? timestamp { get; set; }
    }

    private async Task LoadSeatContext()
    {
        try
        {
            BotDto? seat = null;

            if (!string.IsNullOrWhiteSpace(SeatSlug))
            {
                isPublicMode = true;
                var bySlugResponse = await Http.GetAsync($"/api/seats/by-slug/{SeatSlug}");
                if (bySlugResponse.IsSuccessStatusCode)
                {
                    seat = await bySlugResponse.Content.ReadFromJsonAsync<BotDto>();
                }
            }

            if (seat == null && !string.IsNullOrWhiteSpace(BotId))
            {
                var byIdResponse = await Http.GetAsync($"/api/bot/{BotId}");
                if (byIdResponse.IsSuccessStatusCode)
                {
                    seat = await byIdResponse.Content.ReadFromJsonAsync<BotDto>();
                }
            }

            if (seat == null)
            {
                conversationId = BuildConversationId(null);
                return;
            }

            seatId = seat.Id;
            allowedDomain = GetDomainHost(seat.SiteUrl);
            seatContextLabel = allowedDomain ?? seat.Name;

            if (!isPublicMode)
            {
                trainingManageUrl = $"/bot/{seat.Id}";
                trainingUrlsApiUrl = $"/api/bot/{seat.Id}/urls";
                trainingDocumentsApiUrl = $"/api/bot/{seat.Id}/documents";
            }

            conversationId = BuildConversationId(seat.Id);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load seat context");
            conversationId = BuildConversationId(null);
        }
    }

    private static string? GetDomainHost(string? siteUrl)
    {
        if (string.IsNullOrWhiteSpace(siteUrl))
        {
            return null;
        }

        if (Uri.TryCreate(siteUrl, UriKind.Absolute, out var absolute))
        {
            return absolute.Host;
        }

        if (Uri.TryCreate($"https://{siteUrl}", UriKind.Absolute, out var inferred))
        {
            return inferred.Host;
        }

        return null;
    }

    private string SanitizeLinksForSeat(string message)
    {
        if (string.IsNullOrWhiteSpace(allowedDomain))
        {
            return message;
        }

        return System.Text.RegularExpressions.Regex.Replace(
            message,
            @"https?://[^\s]+",
            match =>
            {
                if (!Uri.TryCreate(match.Value, UriKind.Absolute, out var uri))
                {
                    return "(malformed link removed)";
                }

                return uri.Host.Equals(allowedDomain, StringComparison.OrdinalIgnoreCase)
                    || uri.Host.EndsWith($".{allowedDomain}", StringComparison.OrdinalIgnoreCase)
                    ? match.Value
                    : $"(external link not shown: only {allowedDomain} links are displayed)";
            });
    }

    private static string BuildConversationId(string? seat)
    {
        return $"{(string.IsNullOrWhiteSpace(seat) ? "public" : seat)}-{Guid.NewGuid()}";
    }
}

<style>
    .chat-container {
        display: flex;
        flex-direction: column;
        height: 600px;
        border: 1px solid #ddd;
        border-radius: 8px;
        background: white;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .chat-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px 20px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 8px 8px 0 0;
    }

    .seat-context-banner {
        padding: 10px 20px;
        background: #f5f7ff;
        border-bottom: 1px solid #e0e4ff;
        font-size: 13px;
        color: #444;
    }

    .seat-training-banner {
        background: #eef9f0;
        border-bottom: 1px solid #d8f0dd;
    }

    .chat-header h3 {
        margin: 0;
        font-size: 18px;
    }

    .btn-clear {
        background: rgba(255,255,255,0.2);
        border: 1px solid rgba(255,255,255,0.3);
        color: white;
        padding: 5px 15px;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-clear:hover {
        background: rgba(255,255,255,0.3);
    }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        background: #f5f5f5;
    }

    .message {
        margin-bottom: 15px;
        animation: slideIn 0.3s ease;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .message-content {
        padding: 12px 16px;
        border-radius: 8px;
        max-width: 80%;
    }

    .message.user .message-content {
        background: #667eea;
        color: white;
        margin-left: auto;
    }

    .message.assistant .message-content {
        background: white;
        color: #333;
        border: 1px solid #ddd;
    }

    .message-content strong {
        display: block;
        margin-bottom: 5px;
        font-size: 12px;
        opacity: 0.8;
    }

    .message-content p {
        margin: 0;
        line-height: 1.5;
    }

    .message-content small {
        display: block;
        margin-top: 5px;
        font-size: 10px;
        opacity: 0.6;
    }

    .typing-indicator {
        display: flex;
        gap: 4px;
        padding: 10px;
    }

    .typing-indicator span {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #667eea;
        animation: typing 1.4s infinite;
    }

    .typing-indicator span:nth-child(2) {
        animation-delay: 0.2s;
    }

    .typing-indicator span:nth-child(3) {
        animation-delay: 0.4s;
    }

    @@keyframes typing {
        0%, 60%, 100% {
            opacity: 0.3;
            transform: scale(0.8);
        }
        30% {
            opacity: 1;
            transform: scale(1);
        }
    }

    .chat-input-container {
        display: flex;
        gap: 10px;
        padding: 15px;
        background: white;
        border-top: 1px solid #ddd;
    }

    .chat-input {
        flex: 1;
        padding: 10px;
        border: 1px solid #ddd;
        border-radius: 4px;
        resize: none;
        font-family: inherit;
    }

    .chat-input:focus {
        outline: none;
        border-color: #667eea;
    }

    .btn-send {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-send:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
    }

    .btn-send:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .chat-settings {
        display: flex;
        gap: 20px;
        padding: 15px;
        background: #f8f9fa;
        border-top: 1px solid #ddd;
        border-radius: 0 0 8px 8px;
    }

    .setting-group {
        flex: 1;
    }

    .setting-group label {
        display: block;
        margin-bottom: 5px;
        font-size: 12px;
        color: #666;
    }

    .setting-group input[type="range"] {
        width: 100%;
    }
</style>
