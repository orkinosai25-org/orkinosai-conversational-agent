@page "/admin/adverts"
@inject HttpClient Http
@inject NavigationManager Navigation
@using SiteChatCMS.Shared.DTOs.Adverts

<PageTitle>Advert Management — Admin Console</PageTitle>

<div class="advert-admin">
    <div class="admin-header">
        <div>
            <h1>📢 Advert Management Console</h1>
            <p class="subtitle">Manage advertisement campaigns, review submissions and monitor performance.</p>
        </div>
        <a href="/adverts/buy" class="btn btn-outline">🛍️ Customer Buy Page</a>
    </div>

    @if (loading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading adverts...</p>
        </div>
    }
    else
    {
        <!-- ── Stats dashboard ── -->
        @if (stats != null)
        {
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon">📋</div>
                    <div class="stat-body">
                        <div class="stat-value">@stats.TotalAdverts</div>
                        <div class="stat-label">Total Adverts</div>
                    </div>
                </div>
                <div class="stat-card active">
                    <div class="stat-icon">✅</div>
                    <div class="stat-body">
                        <div class="stat-value">@stats.ActiveAdverts</div>
                        <div class="stat-label">Active</div>
                    </div>
                </div>
                <div class="stat-card pending">
                    <div class="stat-icon">⏳</div>
                    <div class="stat-body">
                        <div class="stat-value">@stats.PendingAdverts</div>
                        <div class="stat-label">Pending Review</div>
                    </div>
                </div>
                <div class="stat-card revenue">
                    <div class="stat-icon">💰</div>
                    <div class="stat-body">
                        <div class="stat-value">$@stats.TotalRevenue.ToString("0.00")</div>
                        <div class="stat-label">Total Revenue</div>
                    </div>
                </div>
                <div class="stat-card impressions">
                    <div class="stat-icon">👁️</div>
                    <div class="stat-body">
                        <div class="stat-value">@FormatNumber(stats.TotalImpressions)</div>
                        <div class="stat-label">Impressions</div>
                    </div>
                </div>
                <div class="stat-card clicks">
                    <div class="stat-icon">🖱️</div>
                    <div class="stat-body">
                        <div class="stat-value">@FormatNumber(stats.TotalClicks)</div>
                        <div class="stat-label">Clicks</div>
                    </div>
                </div>
            </div>
        }

        <!-- ── Advert tiers reference ── -->
        @if (tiers != null && tiers.Any())
        {
            <div class="section">
                <h2>📦 Advert Tiers</h2>
                <div class="tiers-grid">
                    @foreach (var tier in tiers)
                    {
                        <div class="tier-card @(tier.Id == 1 ? "cheapest" : "")">
                            @if (tier.Id == 1)
                            {
                                <span class="tier-badge">Cheapest — Ads Always Shown</span>
                            }
                            <h3>@tier.Name</h3>
                            <div class="tier-price">$@tier.MonthlyPrice.ToString("0.00")<span>/month</span></div>
                            <p>@tier.Description</p>
                            <ul class="tier-features">
                                <li>⏱️ Up to @tier.MaxDurationDays days</li>
                                <li>📍 @string.Join(", ", tier.AllowedPlacements)</li>
                                <li>👁️ @(tier.MaxImpressions == 0 ? "Unlimited impressions" : $"Up to {FormatNumber(tier.MaxImpressions)} impressions")</li>
                                @if (tier.IsPriorityPlacement)
                                {
                                    <li>⭐ Priority placement</li>
                                }
                            </ul>
                            <span class="tier-status @(tier.IsActive ? "active" : "inactive")">
                                @(tier.IsActive ? "Active" : "Inactive")
                            </span>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- ── Filter bar ── -->
        <div class="section">
            <div class="section-header">
                <h2>📋 All Adverts</h2>
                <div class="filter-bar">
                    <select class="form-control" @onchange="OnStatusFilterChange">
                        <option value="">All Statuses</option>
                        <option value="Pending">Pending</option>
                        <option value="Active">Active</option>
                        <option value="Paused">Paused</option>
                        <option value="Expired">Expired</option>
                        <option value="Rejected">Rejected</option>
                    </select>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(actionMessage))
            {
                <div class="alert @(actionSuccess ? "alert-success" : "alert-danger")">
                    @actionMessage
                </div>
            }

            @if (filteredAdverts.Any())
            {
                <div class="adverts-table-wrapper">
                    <table class="adverts-table">
                        <thead>
                            <tr>
                                <th>Advert</th>
                                <th>Tier / Placement</th>
                                <th>Advertiser</th>
                                <th>Dates</th>
                                <th>Performance</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var advert in filteredAdverts)
                            {
                                <tr>
                                    <td>
                                        <div class="advert-title">@advert.Title</div>
                                        <div class="advert-desc">@advert.Description</div>
                                        @if (!string.IsNullOrEmpty(advert.ImageUrl))
                                        {
                                            <a href="@advert.ImageUrl" target="_blank" class="small-link">🖼️ Image</a>
                                        }
                                        <a href="@advert.TargetUrl" target="_blank" class="small-link">🔗 @TruncateUrl(advert.TargetUrl)</a>
                                    </td>
                                    <td>
                                        <span class="badge badge-tier">@advert.TierName</span><br />
                                        <span class="badge badge-placement">@advert.Placement</span>
                                        <div class="revenue-chip">$@advert.AmountPaid.ToString("0.00")</div>
                                    </td>
                                    <td>
                                        <div>@advert.AdvertiserName</div>
                                        <div class="small-text">@advert.AdvertiserEmail</div>
                                    </td>
                                    <td>
                                        <div>▶ @advert.StartDate.ToString("MMM dd, yyyy")</div>
                                        <div>■ @advert.EndDate.ToString("MMM dd, yyyy")</div>
                                    </td>
                                    <td>
                                        <div>👁️ @FormatNumber(advert.ImpressionCount)</div>
                                        <div>🖱️ @FormatNumber(advert.ClickCount)</div>
                                        <div class="ctr">CTR: @CalculateCtr(advert.ImpressionCount, advert.ClickCount)%</div>
                                    </td>
                                    <td>
                                        <span class="status-badge status-@advert.Status.ToLower()">@advert.Status</span>
                                    </td>
                                    <td>
                                        <div class="action-buttons">
                                            @if (advert.Status == "Pending")
                                            {
                                                <button class="btn btn-sm btn-success" @onclick="() => ApproveAdvert(advert.Id)">✅ Approve</button>
                                                <button class="btn btn-sm btn-danger" @onclick="() => RejectAdvert(advert.Id)">❌ Reject</button>
                                            }
                                            @if (advert.Status == "Active")
                                            {
                                                <button class="btn btn-sm btn-warning" @onclick="() => PauseAdvert(advert.Id)">⏸️ Pause</button>
                                            }
                                            @if (advert.Status == "Paused")
                                            {
                                                <button class="btn btn-sm btn-success" @onclick="() => ApproveAdvert(advert.Id)">▶️ Resume</button>
                                            }
                                            <button class="btn btn-sm btn-secondary" @onclick="() => EditAdvert(advert)">✏️ Edit</button>
                                            <button class="btn btn-sm btn-danger" @onclick="() => ConfirmDelete(advert)">🗑️ Delete</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <span>📭</span>
                    <p>No adverts match the current filter.</p>
                </div>
            }
        </div>
    }
</div>

<!-- ── Edit modal ── -->
@if (editingAdvert != null)
{
    <div class="modal-overlay" @onclick="CloseEditModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>✏️ Edit Advert</h2>
                <button class="close-btn" @onclick="CloseEditModal">×</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Title</label>
                    <input class="form-control" @bind="editingAdvert.Title" />
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea class="form-control" rows="3" @bind="editingAdvert.Description"></textarea>
                </div>
                <div class="form-group">
                    <label>Image URL</label>
                    <input class="form-control" @bind="editingAdvert.ImageUrl" />
                </div>
                <div class="form-group">
                    <label>Target URL</label>
                    <input class="form-control" @bind="editingAdvert.TargetUrl" />
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Start Date</label>
                        <input type="date" class="form-control" @bind="editStartDate" />
                    </div>
                    <div class="form-group">
                        <label>End Date</label>
                        <input type="date" class="form-control" @bind="editEndDate" />
                    </div>
                </div>
                <div class="form-group">
                    <label>Status</label>
                    <select class="form-control" @bind="editingAdvert.Status">
                        <option value="Pending">Pending</option>
                        <option value="Active">Active</option>
                        <option value="Paused">Paused</option>
                        <option value="Expired">Expired</option>
                        <option value="Rejected">Rejected</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Admin Notes</label>
                    <textarea class="form-control" rows="2" @bind="editingAdvert.Notes"></textarea>
                </div>
                <div class="modal-actions">
                    <button class="btn btn-secondary" @onclick="CloseEditModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveEdit">Save Changes</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- ── Delete confirmation modal ── -->
@if (deletingAdvert != null)
{
    <div class="modal-overlay" @onclick="CloseDeleteModal">
        <div class="modal-content modal-sm" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>🗑️ Delete Advert</h2>
                <button class="close-btn" @onclick="CloseDeleteModal">×</button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to permanently delete "<strong>@deletingAdvert.Title</strong>"?</p>
                <p class="text-muted">This action cannot be undone.</p>
                <div class="modal-actions">
                    <button class="btn btn-secondary" @onclick="CloseDeleteModal">Cancel</button>
                    <button class="btn btn-danger" @onclick="DeleteAdvert">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .advert-admin {
        max-width: 1400px;
        margin: 0 auto;
        padding: 40px 20px;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

