    }

    .section h2 {
        font-size: 1.4em;
        margin: 0 0 20px 0;
        color: #222;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 12px;
