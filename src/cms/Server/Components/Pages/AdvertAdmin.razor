        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 36px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .admin-header h1 {
        font-size: 2.2em;
        margin: 0 0 8px 0;
