    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
</style>

@code {
    private List<AdvertDto>? allAdverts;
    private List<AdvertDto> filteredAdverts = new();
    private List<AdvertTierDto>? tiers;
    private AdvertStatsDto? stats;
    private bool loading = true;
    private string statusFilter = "";
    private string? actionMessage;
    private bool actionSuccess;

    // Edit state
    private AdvertDto? editingAdvert;
    private DateTime editStartDate;
    private DateTime editEndDate;

    // Delete state
    private AdvertDto? deletingAdvert;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        loading = true;
        try
        {
            var advertsTask = Http.GetFromJsonAsync<List<AdvertDto>>("/api/advert/admin/all");
            var tiersTask = Http.GetFromJsonAsync<List<AdvertTierDto>>("/api/advert/tiers");
            var statsTask = Http.GetFromJsonAsync<AdvertStatsDto>("/api/advert/admin/stats");

            await Task.WhenAll(advertsTask, tiersTask, statsTask);

            allAdverts = await advertsTask ?? new List<AdvertDto>();
            tiers = await tiersTask;
            stats = await statsTask;

            ApplyFilter();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading advert data: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private void ApplyFilter()
    {
        filteredAdverts = string.IsNullOrEmpty(statusFilter)
            ? allAdverts ?? new List<AdvertDto>()
            : (allAdverts ?? new List<AdvertDto>()).Where(a => a.Status == statusFilter).ToList();
    }

    private void OnStatusFilterChange(ChangeEventArgs e)
    {
        statusFilter = e.Value?.ToString() ?? "";
        ApplyFilter();
    }

    private async Task ApproveAdvert(int id)
    {
        var resp = await Http.PostAsync($"/api/advert/admin/{id}/approve", null);
        if (resp.IsSuccessStatusCode)
        {
            SetMessage("Advert approved successfully.", true);
            await LoadDataAsync();
        }
        else
        {
            SetMessage("Failed to approve advert.", false);
        }
    }

    private async Task PauseAdvert(int id)
    {
        var resp = await Http.PostAsync($"/api/advert/admin/{id}/pause", null);
        if (resp.IsSuccessStatusCode)
        {
            SetMessage("Advert paused.", true);
            await LoadDataAsync();
        }
        else
        {
            SetMessage("Failed to pause advert.", false);
        }
    }

    private async Task RejectAdvert(int id)
    {
        var resp = await Http.PostAsync($"/api/advert/admin/{id}/reject", null);
        if (resp.IsSuccessStatusCode)
        {
            SetMessage("Advert rejected.", true);
            await LoadDataAsync();
        }
        else
        {
            SetMessage("Failed to reject advert.", false);
        }
    }

    private void EditAdvert(AdvertDto advert)
    {
        editingAdvert = new AdvertDto
        {
            Id = advert.Id,
            Title = advert.Title,
            Description = advert.Description,
            ImageUrl = advert.ImageUrl,
            TargetUrl = advert.TargetUrl,
            TierId = advert.TierId,
            TierName = advert.TierName,
            Placement = advert.Placement,
            Status = advert.Status,
            AdvertiserName = advert.AdvertiserName,
            AdvertiserEmail = advert.AdvertiserEmail,
            StartDate = advert.StartDate,
            EndDate = advert.EndDate,
            ImpressionCount = advert.ImpressionCount,
            ClickCount = advert.ClickCount,
            AmountPaid = advert.AmountPaid,
            Notes = advert.Notes,
            CreatedAt = advert.CreatedAt
        };
        editStartDate = advert.StartDate.Date;
        editEndDate = advert.EndDate.Date;
    }

    private void CloseEditModal() => editingAdvert = null;

    private async Task SaveEdit()
    {
        if (editingAdvert == null) return;

        editingAdvert.StartDate = editStartDate;
        editingAdvert.EndDate = editEndDate;

        var updateDto = new UpdateAdvertDto
        {
            Title = editingAdvert.Title,
            Description = editingAdvert.Description,
            ImageUrl = editingAdvert.ImageUrl,
            TargetUrl = editingAdvert.TargetUrl,
            Status = editingAdvert.Status,
            StartDate = editingAdvert.StartDate,
            EndDate = editingAdvert.EndDate,
            Notes = editingAdvert.Notes
        };

        var resp = await Http.PutAsJsonAsync($"/api/advert/admin/{editingAdvert.Id}", updateDto);
        if (resp.IsSuccessStatusCode)
        {
            SetMessage("Advert updated successfully.", true);
            CloseEditModal();
            await LoadDataAsync();
        }
        else
        {
            SetMessage("Failed to update advert.", false);
        }
    }

    private void ConfirmDelete(AdvertDto advert) => deletingAdvert = advert;

    private void CloseDeleteModal() => deletingAdvert = null;

    private async Task DeleteAdvert()
    {
        if (deletingAdvert == null) return;
        var resp = await Http.DeleteAsync($"/api/advert/admin/{deletingAdvert.Id}");
        if (resp.IsSuccessStatusCode)
        {
            SetMessage("Advert deleted.", true);
            CloseDeleteModal();
            await LoadDataAsync();
        }
        else
        {
            SetMessage("Failed to delete advert.", false);
            CloseDeleteModal();
        }
    }

    private void SetMessage(string message, bool success)
    {
        actionMessage = message;
        actionSuccess = success;
    }

    private static string FormatNumber(long n) =>
        n >= 1_000_000 ? $"{n / 1_000_000.0:0.#}M"
        : n >= 1_000 ? $"{n / 1_000.0:0.#}K"
        : n.ToString();

    private static string TruncateUrl(string url, int max = 30) =>
        url.Length > max ? url[..max] + "…" : url;

    private static string CalculateCtr(int impressions, int clicks) =>
        impressions == 0 ? "0.00" : (clicks * 100.0 / impressions).ToString("0.00");
}
